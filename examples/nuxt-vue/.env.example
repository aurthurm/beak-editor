# Copy to `.env` or `.env.local` in this directory (same folder as `nuxt.config.ts`), then restart `pnpm dev`.
# `.env.local` is supported; do not create a folder named `.env` — use a file.
# Server route uses the Vercel AI SDK (packages `ai` + `@ai-sdk/openai`).
# Get a key from https://platform.openai.com/api-keys

OPENAI_API_KEY=

# Optional overrides (defaults match nuxt.config.ts)
# BEAKBLOCK_AI_MODEL=gpt-4.1-mini
# BEAKBLOCK_AI_BASE_URL=https://api.openai.com

# Nuxt also accepts this name for the same secret (e.g. in hosting dashboards):
# NUXT_OPENAI_API_KEY=
