{
  "name": "@amusendame/beakblock-core",
  "version": "0.1.2",
  "description": "Framework-agnostic core for BeakBlock editor",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js"
    },
    "./styles": "./dist/styles/editor.css",
    "./styles/editor.css": "./dist/styles/editor.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "editor",
    "rich-text",
    "prosemirror",
    "block-editor",
    "wysiwyg",
    "notion-like",
    "typescript",
    "text-editor",
    "content-editor",
    "document-editor"
  ],
  "scripts": {
    "build": "vite build && cp -r src/styles dist/",
    "dev": "vite build --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "hast-util-to-html": "^9.0.5",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "mdast-util-to-markdown": "^2.1.2",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.24.1",
    "prosemirror-schema-list": "^1.4.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.37.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/uuid": "^10.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "y-prosemirror": "^1.0.0",
    "yjs": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "yjs": {
      "optional": true
    },
    "y-prosemirror": {
      "optional": true
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aurthurm/beakblock.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/aurthurm/beakblock#readme",
  "bugs": {
    "url": "https://github.com/aurthurm/beakblock/issues"
  }
}
