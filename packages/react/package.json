{
  "name": "@amusendame/beakblock-react",
  "version": "0.1.2",
  "description": "React bindings for BeakBlock editor",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "editor",
    "rich-text",
